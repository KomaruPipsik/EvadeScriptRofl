-- ==========================================
-- Логика перетаскивания меню (Drag & Drop)
-- ==========================================
local dragging = false
local dragInput, mousePos, framePos

Title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		mousePos = input.Position
		framePos = MainFrame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

Title.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

RunService.RenderStepped:Connect(function()
	if dragging and dragInput then
		local delta = dragInput.Position - mousePos
		MainFrame.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
	end
end)

-- ==========================================
-- Логика функций (Не визуал, реплицируется)
-- ==========================================

-- Вспомогательная функция для получения главного сустава (поддерживает R6 и R15)
local function getRootJoint(character)
	if character then
		if character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart:FindFirstChild("RootJoint") then
			return character.HumanoidRootPart.RootJoint -- R6
		elseif character:FindFirstChild("LowerTorso") and character.LowerTorso:FindFirstChild("Root") then
			return character.LowerTorso.Root -- R15
		end
	end
	return nil
end

-- 1. Перевернутый скин
local function applyFlip(character)
	local joint = getRootJoint(character)
	if joint then
		-- Поворот на 180 градусов (math.pi) по оси Z
		joint.C0 = joint.C0 * CFrame.Angles(0, 0, math.pi)
	end
end

FlipButton.MouseButton1Click:Connect(function()
	isFlipped = not isFlipped
	if isFlipped then
		FlipButton.Text = "Переворот: ВКЛ"
		FlipButton.TextColor3 = Color3.fromRGB(100, 255, 100)
		applyFlip(player.Character)
	else
		FlipButton.Text = "Переворот: ВЫКЛ"
		FlipButton.TextColor3 = Color3.fromRGB(255, 100, 100)
		-- Возвращаем обратно
		applyFlip(player.Character)
	end
end)

-- Автоматически переворачивать при возрождении, если функция включена
player.CharacterAdded:Connect(function(newChar)
	if isFlipped then
		task.wait(0.5) -- Ждем загрузки суставов
		applyFlip(newChar)
	end
end)

-- 2. Не терять скорость (Сохранение инерции)
SpeedButton.MouseButton1Click:Connect(function()
	keepSpeed = not keepSpeed
	if keepSpeed then
		SpeedButton.Text = "Инерция: ВКЛ"
		SpeedButton.TextColor3 = Color3.fromRGB(100, 255, 100)
	else
		SpeedButton.Text = "Инерция: ВЫКЛ"
		SpeedButton.TextColor3 = Color3.fromRGB(255, 100, 100)
	end
end)

-- Цикл обработки скорости каждый кадр
RunService.RenderStepped:Connect(function()
	if not keepSpeed then return end
	
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
		local hrp = char.HumanoidRootPart
		local hum = char.Humanoid
		
		-- Если игрок жмет кнопки движения (идет)
		if hum.MoveDirection.Magnitude > 0 then
			-- Записываем текущую скорость по осям X и Z (без Y, чтобы не улетать вверх)
			lastVelocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
		else
			-- Если игрок стоит на месте (отпустил кнопки), принудительно применяем сохраненную скорость
			-- Y-компонента берется оригинальная, чтобы гравитация работала нормально (игрок мог падать)
			hrp.Velocity = Vector3.new(lastVelocity.X, hrp.Velocity.Y, lastVelocity.Z)
		end
	end
end)
