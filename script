-- Поиск нормали поверхности
local function checkSurfaces(char)
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return nil end

	rayParams.FilterDescendantsInstances = {char}

	local checkDirections = {
		-hrp.CFrame.UpVector * 5,
		hrp.CFrame.LookVector * 4,
		-hrp.CFrame.LookVector * 4,
		hrp.CFrame.RightVector * 4,
		-hrp.CFrame.RightVector * 4,
		hrp.CFrame.UpVector * 5
	}

	for _, dir in ipairs(checkDirections) do
		local result = workspace:Raycast(hrp.Position, dir, rayParams)
		if result and result.Instance and result.Instance.CanCollide then
			return result.Normal
		end
	end
	return nil
end

-- ==========================================
-- Игровые циклы
-- ==========================================

-- 1. Поддержание Переворота (перекрывает стандартные анимации Roblox)
RunService.RenderStepped:Connect(function()
	if not isFlipped then return end
	
	local char = player.Character
	local joint = getRootJoint(char)
	if joint then
		if not originalC0 then
			originalC0 = joint.C0
		end
		joint.C0 = originalC0 * CFrame.Angles(0, 0, math.pi)
	end
end)

-- 2. Поддержание Инерции
RunService.Heartbeat:Connect(function()
	if not keepSpeed then return end
	
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	
	if hrp and hum and hum.Health > 0 then
		if hum.MoveDirection.Magnitude > 0.1 then
			-- Фиксируем текущий вектор движения во время бега
			savedVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
		else
			-- При отпущенных кнопках продолжается скольжение по направлению
			if savedVelocity.Magnitude > 1 then
				hrp.AssemblyLinearVelocity = Vector3.new(savedVelocity.X, hrp.AssemblyLinearVelocity.Y, savedVelocity.Z)
			end
		end
	end
end)

-- 3. Стенолазание
RunService.Stepped:Connect(function(_, dt)
	if not isWallWalking then return end
	
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	
	if hrp and hum and hum.Health > 0 then
		local normal = checkSurfaces(char)
		if normal then
			local currentLook = hrp.CFrame.LookVector
			local right = currentLook:Cross(normal)
			if right.Magnitude > 0.001 then
				local forward = normal:Cross(right).Unit
				hrp.CFrame = CFrame.fromMatrix(hrp.Position, right.Unit, normal, -forward)
			end

			local antiGravity = Vector3.new(0, workspace.Gravity * dt, 0)
			local stickForce = -normal * 30 * dt
			hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity + antiGravity + stickForce
		end
	end
end)
