-- ==========================================
-- Логика перетаскивания меню (Drag & Drop)
-- ==========================================
local dragging = false
local dragInput, mousePos, framePos

Title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		mousePos = input.Position
		framePos = MainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

Title.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

RunService.RenderStepped:Connect(function()
	if dragging and dragInput then
		local delta = dragInput.Position - mousePos
		MainFrame.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
	end
end)

-- ==========================================
-- Логика функций 
-- ==========================================
local isFlipped = false
local keepSpeed = false
local lastVelocity = Vector3.new(0, 0, 0)
local originalC0 = nil

local function getRootJoint(character)
	if character then
		if character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart:FindFirstChild("RootJoint") then
			return character.HumanoidRootPart.RootJoint -- R6
		elseif character:FindFirstChild("LowerTorso") and character.LowerTorso:FindFirstChild("Root") then
			return character.LowerTorso.Root -- R15
		end
	end
	return nil
end

-- 1. Перевернутый скин
FlipButton.MouseButton1Click:Connect(function()
	isFlipped = not isFlipped
	local joint = getRootJoint(player.Character)
	
	if joint then
		-- Сохраняем оригинальную позицию сустава, если еще не сохранили
		if not originalC0 then
			originalC0 = joint.C0
		end
		
		if isFlipped then
			FlipButton.Text = "Переворот: ВКЛ"
			FlipButton.TextColor3 = Color3.fromRGB(100, 255, 100)
			-- Переворачиваем персонажа вверх ногами (поворот по оси Z)
			joint.C0 = originalC0 * CFrame.Angles(0, 0, math.pi)
		else
			FlipButton.Text = "Переворот: ВЫКЛ"
			FlipButton.TextColor3 = Color3.fromRGB(255, 100, 100)
			-- Возвращаем как было
			joint.C0 = originalC0
		end
	end
end)

-- 2. Не терять скорость (Сохранение инерции)
SpeedButton.MouseButton1Click:Connect(function()
	keepSpeed = not keepSpeed
	if keepSpeed then
		SpeedButton.Text = "Инерция: ВКЛ"
		SpeedButton.TextColor3 = Color3.fromRGB(100, 255, 100)
	else
		SpeedButton.Text = "Инерция: ВЫКЛ"
		SpeedButton.TextColor3 = Color3.fromRGB(255, 100, 100)
	end
end)

-- Запуск проверки физики после каждого шага симуляции
RunService.Stepped:Connect(function()
	if not keepSpeed then return end
	
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
		local hrp = char.HumanoidRootPart
		local hum = char.Humanoid
		
		if hum.MoveDirection.Magnitude > 0 then
			-- Игрок движется — записываем его текущую физическую скорость
			lastVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
		else
			-- Игрок отпустил кнопки — заставляем его скользить дальше
			hrp.AssemblyLinearVelocity = Vector3.new(lastVelocity.X, hrp.AssemblyLinearVelocity.Y, lastVelocity.Z)
		end
	end
end)
